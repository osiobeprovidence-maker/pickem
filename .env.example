# Public Vite variables used by the client app.
# Add these in Vercel Project Settings -> Environment Variables.

VITE_FIREBASE_API_KEY="your_firebase_web_api_key"
# Use the Firebase auth host only. Do not use https:// and do not use identitytoolkit.googleapis.com here.
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_firebase_app_id"
VITE_FIREBASE_MEASUREMENT_ID="your_measurement_id"

VITE_CONVEX_URL="https://your-deployment.convex.cloud"
VITE_CONVEX_SITE_URL="https://your-deployment.convex.site"

# Optional public app URL. If omitted, the browser origin is used.
# Local dev for this project runs on http://localhost:3000 via the Express + Vite server in server.ts.
VITE_APP_URL="https://your-domain.vercel.app"
